{
  "name": "tasky-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:api": "openapi-typescript ../backend/api/openapi.yaml -o src/api/schema.d.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run gen:api && npm run typecheck && vite build"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "openapi-fetch": "^0.13.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
